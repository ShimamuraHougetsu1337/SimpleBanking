# Environment Variables — Simple Banking App (Backend)
# Copy file này thành .env và điền giá trị thực tế
# KHÔNG commit file .env lên Git

# ================================================================
# SERVER CONFIGURATION
# ================================================================
PORT=3000
NODE_ENV=development

# ================================================================
# DATABASE CONFIGURATION
# ================================================================
DB_HOST=localhost
DB_PORT=5432
DB_NAME=banking_db
DB_USERNAME=banking_user
DB_PASSWORD=change_this_to_a_strong_password

# ================================================================
# SECURITY & JWT CONFIGURATION
# ================================================================
# Tạo bằng lệnh: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
# Mỗi secret phải ít nhất 64 ký tự và KHÁC NHAU
JWT_ACCESS_SECRET=replace_with_64plus_char_random_string_for_access_token
JWT_REFRESH_SECRET=replace_with_different_64plus_char_random_string_for_refresh
ACCESS_TOKEN_EXPIRES_IN=15m
REFRESH_TOKEN_EXPIRES_IN=7d

# ================================================================
# CORS & FRONTEND URL CONFIGURATION
# ================================================================
# URL của frontend để config CORS
FRONTEND_URL=http://localhost:5173
